# ──────────────────────────────────────────────
# Telegram Bot Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# REQUIRED — Get your token from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# OPTIONAL — Customize for each client
BUSINESS_NAME=My Awesome Business
DATABASE_PATH=bot_database.db
LOG_LEVEL=INFO

# OPTIONAL — Override default text (one-line strings)
# SERVICES_TEXT=...
# PRICING_TEXT=...
# CONTACT_TEXT=...
# LOCATION_TEXT=...
